name: Machine Innovation CI CD Pipeline

on:
  push:
    branches:
      - "main"
    
  pull_request:
    branches: 
      - "main"

  # Avviaamento secondo due modalità (vedere file deployment.md)
  # Avviamento schedulato con airflow (una volta al mese)
  workflow_dispatch:
    inputs:
      mode:
        description: "Seleziona la modalità di esecuzione (demo o prod)"
        default: "demo"
        type: choice
        options:
          - "demo"
          - "prod"

permissions:
  # da verificare
  # contents: read
  contents: write

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout del codice
        uses: actions/checkout@v4

      - name: Set up Python 3.12
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: "pip"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install pytest
          if [ -f requirements.txt ]; then pip install -r requirements.txt; fi

      - name: Test with pytest 
        env:
          HF_TOKEN: ${{ secrets.HF_TOKEN }}
        working-directory: "."
        run: |
          chmod +x ./run_test_ci.sh
          ./run_test_ci.sh

  # viene eseguito solo se il job
  # di test ha successo.
  train:
    needs: test
    # il train viene eseguito solo sul branch di main
    if: github.ref == 'refs/heads/main'
    runs-on: ubuntu-latest
    steps:
      
      - name: Checkout del codice
        uses: actions/checkout@v4

      - name: Set up Python 3.12
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: "pip"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install pytest
          if [ -f requirements.txt ]; then pip install -r requirements.txt; fi

      - name: Run train
        env:
          HF_TOKEN_WRITE: ${{ secrets.HF_TOKEN_WRITE }}
        run: |
          chmod +x ./run_train_prod.sh
          
          # Controlla l'input del workflow_dispatch (default=demo) 
          # se attivato da push/PR) - Vedere documentazione deployment
          if [ "${{ github.event.inputs.mode }}" = "prod" ]; then
            echo "Avvio training in modalità PRODUCTION..."
            echo "Attivare Cpu con 4-core..."
            ./run_train_prod.sh
            echo "MODEL_OUT_DIR=src/outputs-baseline-prod" >> $GITHUB_ENV
          else
            echo "Avvio training in modalità DEMO..."
            ./run_train_prod.sh --demo
            echo "MODEL_OUT_DIR=src/outputs-baseline-debug" >> $GITHUB_ENV
          fi    

      # se il train ha successo il modello viene
      # caricato su repository tipo model di Hugging Face
      - name: Upload Model to Hugging Face
        env:
          HF_TOKEN_WRITE: ${{ secrets.HF_TOKEN_WRITE }}
        run: |
          python ci_cd/CD/hf_deploy.py

      # INVIA IL CODICE DI SERVING ALLO SPACE DI HUGGING FACE 
      - name: Deploy to Hugging Face Spaces
        env:
          HF_TOKEN_WRITE: ${{ secrets.HF_TOKEN_WRITE }}
          # PER SCARICARE IL FILE model.safetensors
          # BISOGNA ABILITARE IL DOWNLOAD DEI FILE PESANTI LFS IN SCRITTURA
          GIT_LFS_SKIP_SMUDGE: 1 
        run: |
          # Configura Git con un utente fittizio
          git config --global user.email "francescofrigerio529@gmail.com"
          git config --global user.name "francescofrigerio"
          
          # Clona lo Space di Hugging Face in una cartella temporanea usando il tuo Token
          # Sostituisci "NOME_UTENTE" e "NOME_SPACE" con i tuoi dati reali
          git clone https://x:$HF_TOKEN_WRITE@huggingface.co/spaces/francescofrigerio/spacemachineinnovatorsmlops hf_space
          
          # Svuota la cartella dello Space (tranne i file Git) e copia il nuovo contenuto di model_serving
          # Viene usato 'find' per non cancellare file nascosti come .git o cartelle LFS locali se presenti
          find hf_space -maxdepth 1 -not -name 'hf_space' -not -name '.git' -exec rm -rf {} +

          cp -r model_serving/* hf_space/
          
          # Invio delle modifiche. 
          # Hugging Face fa ripartire lo Space in automatico
          cd hf_space
          git add .
          git diff-index --quiet HEAD || git commit -m "Deploy automatico da GitHub Actions"
          git push origin main
          
      - name: Build model_serving with Dockerfile
        run: |
          docker build -f model_serving/Dockerfile -t machine-innovation-serving:latest ./model_serving

